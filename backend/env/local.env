# ═══════════════════════════════════════════════════════
# 本地开发环境配置 - Local Development Environment
# ═══════════════════════════════════════════════════════

ENV=local
DEBUG=true
SECRET_KEY=local-dev-secret-key-not-for-production

# ── AWS & LLM ──
AWS_REGION=us-east-1
LLM_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ── PostgreSQL (本地) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=securities_trading

# ── Redis (本地) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── AgentCore (本地开发可留空，部署时填写) ──
AGENTCORE_MEMORY_ID=
AGENTCORE_BROWSER_ID=
AGENTCORE_CODE_INTERPRETER_ID=
AGENTCORE_REGISTRY_ID=

# ── 通知 (本地开发可留空) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Server ──
HOST=0.0.0.0
PORT=8000
