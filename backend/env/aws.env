# ═══════════════════════════════════════════════════════
# AWS 部署环境配置 - us-east-1
# ═══════════════════════════════════════════════════════

ENV=aws
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_STRING

# ── AWS & LLM ──
AWS_REGION=us-east-1
LLM_MODEL_ID=us.anthropic.claude-sonnet-4-6
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.3

# ── Amazon Aurora PostgreSQL Serverless v2 ──
POSTGRES_HOST=securities-trading-aurora.cluster-c7b8fns5un9o.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SecuritiesTrading2026Prod
POSTGRES_DB=securities_trading

# ── Amazon ElastiCache Redis Serverless ──
REDIS_HOST=securities-trading-redis-0uiite.serverless.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── AgentCore Resources ──
AGENTCORE_AGENT_ID=SecuritiesTradingAgent-Ma2PoA8Zw8
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:632930644527:runtime/SecuritiesTradingAgent-Ma2PoA8Zw8
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:632930644527:runtime/SecuritiesTradingAgent-Ma2PoA8Zw8
AGENTCORE_MEMORY_ID=SecuritiesTradingMemory-PhU3ojCYpp
AGENTCORE_BROWSER_ID=SecuritiesTradingBrowser-F6aHtUeGkj
AGENTCORE_CODE_INTERPRETER_ID=SecuritiesTradingCodeInterpreter-wGp9YodWEL
AGENTCORE_REGISTRY_ID=Eea8hqxihmpeJlYv

# ── AgentCore Runtime ──
# Name: SecuritiesTradingAgent
# ARN:  arn:aws:bedrock-agentcore:us-east-1:632930644527:runtime/SecuritiesTradingAgent-Ma2PoA8Zw8
# Network: VPC (vpc-0c036c30b82b3703f) - 3 subnets, 1 SG
# Memory: STM (SecuritiesTradingAgent_mem-tqns5J9x7x)

# ── Security Groups (VPC内访问) ──
# Runtime SG: sg-040e6617a7c6800ce (outbound all, inbound from VPC)
# Aurora  SG: sg-028208204b3348d14 (TCP 5432 ← VPC CIDR + Runtime SG)
# Redis   SG: sg-01ccb95bbdbbba483 (TCP 6379 ← VPC CIDR + Runtime SG)

# ── Frontend ──
# S3: sec-trading-web-app-prod (private, OAC only)
# CloudFront: dt0u20qd1sod9.cloudfront.net (EFHJYSE515D2O)

# ── 通知 ──
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=noreply@securities-trading.com
NOTIFICATION_EMAIL_TO=pingaws@amazon.com
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:632930644527:securities-trading-notifications

# ── CORS ──
CORS_ORIGINS=["*"]

# ── Cognito (disabled) ──
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# ── Server ──
HOST=0.0.0.0
PORT=8000
